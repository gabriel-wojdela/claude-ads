# ===========================================
# CREDENCIAIS META ADS API
# ===========================================
# IMPORTANTE: Copie este arquivo para .env e preencha com seus dados reais
# Comando: cp .env.example .env
#
# NUNCA compartilhe o arquivo .env com ninguem
# NUNCA faca commit do .env no git
# ===========================================

# Token de acesso da Meta API
# Gerar em: https://developers.facebook.com/tools/explorer/
# Permissoes necessarias: ads_read, ads_management
META_ACCESS_TOKEN=cole_seu_token_aqui

# ID da conta de anuncios
# Encontrar em: Business Manager > Configuracoes > Contas de anuncios
# Formato: act_XXXXXXXXXXXXXXXXX
META_AD_ACCOUNT_ID=act_0000000000000000

# ID do App no Facebook for Developers
# Encontrar em: https://developers.facebook.com/apps/ > Seu App > Configuracoes > Basico
META_APP_ID=000000000000000

# Secret do App
# Encontrar no mesmo local do App ID
META_APP_SECRET=cole_seu_app_secret_aqui
